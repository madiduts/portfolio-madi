---
---

<section id="hero" class="relative min-h-[85vh] flex flex-col justify-center items-start px-6 md:px-12 max-w-5xl mx-auto overflow-hidden">
  <!-- Glowing Background Effect -->
  <div class="absolute top-1/4 left-1/3 -translate-x-1/2 -translate-y-1/2 w-80 h-80 bg-teal-500/10 rounded-full blur-[120px] pointer-events-none"></div>
  <div class="absolute top-1/3 right-1/4 -translate-y-1/2 w-96 h-96 bg-sky-500/10 rounded-full blur-[150px] pointer-events-none"></div>
  
  <div class="relative z-10 space-y-6 max-w-3xl">
    <!-- Availability Badge -->
    <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-zinc-900 border border-zinc-800 text-xs font-mono text-zinc-400">
      <span class="relative flex h-2 w-2">
        <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-teal-400 opacity-75"></span>
        <span class="relative inline-flex rounded-full h-2 w-2 bg-teal-500"></span>
      </span>
      Membuka Peluang Baru
    </div>

    <!-- Title / Headline -->
    <h1 class="text-4xl sm:text-5xl md:text-7xl font-sans font-bold tracking-tight text-white leading-none">
      Mahdi Imantaka Sutejo
    </h1>
    
    <!-- Subtitle (Display Font) -->
    <p class="text-lg sm:text-xl md:text-2xl font-mono text-teal-400 font-medium">
      &lt;Software Engineer & System Builder /&gt;
    </p>

    <!-- Description (Body Font) -->
    <p class="text-zinc-400 text-base sm:text-lg leading-relaxed max-w-2xl font-sans">
      Saya merancang dan membangun sistem digital berkinerja tinggi yang presisi, 
      mulai dari arsitektur backend hingga antarmuka pengguna yang responsif. Berfokus 
      pada skalabilitas, efisiensi kode, dan solusi berorientasi data.
    </p>

    <!-- Action Buttons -->
    <div class="flex flex-wrap gap-4 pt-2">
      <a 
        href="#projects" 
        class="px-6 py-3 rounded bg-teal-500 hover:bg-teal-400 text-zinc-950 font-medium transition-all duration-300 shadow-lg shadow-teal-500/10 hover:shadow-teal-400/20 text-sm font-sans"
      >
        Lihat Proyek
      </a>
      <a 
        href="#contact" 
        class="px-6 py-3 rounded bg-zinc-900 hover:bg-zinc-800 text-white border border-zinc-850 hover:border-zinc-700 font-medium transition-all duration-300 text-sm font-mono"
      >
        Hubungi Saya
      </a>
    </div>

    <!-- Technical Metadata Info for precision feel -->
    <div class="grid grid-cols-2 md:grid-cols-3 gap-6 pt-12 border-t border-zinc-900 w-full max-w-xl text-xs font-mono text-zinc-500">
      <div>
        <p class="text-zinc-650 uppercase tracking-wider text-[10px]">Lokasi</p>
        <p class="text-zinc-350 mt-1">Jakarta, Indonesia</p>
      </div>
      <div>
        <p class="text-zinc-650 uppercase tracking-wider text-[10px]">Spesialisasi</p>
        <p class="text-zinc-350 mt-1">Web Apps & Data Pipeline</p>
      </div>
      <div class="col-span-2 md:col-span-1">
        <p class="text-zinc-650 uppercase tracking-wider text-[10px]">Tahun Aktif</p>
        <p class="text-zinc-350 mt-1">2021 — Sekarang</p>
      </div>
    </div>
  </div>

  <!-- Real-time cursor coordinates indicator -->
  <div class="hidden lg:block absolute bottom-8 right-12 font-mono text-[10px] text-zinc-700 tracking-wider">
    SYS.LOC // X:<span id="coord-x">000</span> Y:<span id="coord-y">000</span>
  </div>
</section>

<script>
  const coordX = document.getElementById('coord-x');
  const coordY = document.getElementById('coord-y');

  document.addEventListener('mousemove', (e) => {
    if (coordX && coordY) {
      coordX.textContent = String(e.clientX).padStart(3, '0');
      coordY.textContent = String(e.clientY).padStart(3, '0');
    }
  });
</script>
