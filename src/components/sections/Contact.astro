          <!-- Metadata -->
          <div class="min-w-0 flex-grow text-left">
            <span class="block text-[10px] font-mono text-zinc-555 uppercase tracking-wider">Direct Inbox</span>
            <span class="block text-sm font-sans font-bold text-white group-hover:text-teal-400 transition-colors duration-200 truncate">mahdisutejo7@gmail.com</span>
            <span class="block text-[9px] font-mono text-zinc-500 mt-0.5">Response: &lt; 24 Hours // ONLINE</span>
          </div>
          
          <!-- Arrow Indicator -->
          <span class="text-zinc-650 group-hover:text-teal-400 font-mono text-xs pr-2 transition-transform duration-300 group-hover:translate-x-1">→</span>
        </a>

        <!-- LinkedIn Card -->
        <a 
