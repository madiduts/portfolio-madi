</section>

<script>
  // Setup cursor spotlights for the contact cards
  const contactCards = document.querySelectorAll('#contact .card-spotlight');
  contactCards.forEach(card => {
    card.addEventListener('mousemove', (e) => {
      const rect = card.getBoundingClientRect();
      const x = (e as MouseEvent).clientX - rect.left;
      const y = (e as MouseEvent).clientY - rect.top;
      (card as HTMLElement).style.setProperty('--card-mouse-x', `${x}px`);
      (card as HTMLElement).style.setProperty('--card-mouse-y', `${y}px`);
    });
  });
</script>
