            <span class="block text-[10px] font-mono text-zinc-555 uppercase tracking-wider">Visual & Social Feed</span>
            <span class="block text-sm font-sans font-bold text-white group-hover:text-pink-400 transition-colors duration-200 truncate">@madiduts</span>
            <span class="block text-[9px] font-mono text-zinc-500 mt-0.5">Status: ONLINE // FEEDS_ACTIVE</span>
          </div>

          <!-- Arrow Indicator -->
          <span class="text-zinc-650 group-hover:text-pink-400 font-mono text-xs pr-2 transition-transform duration-300 group-hover:translate-x-1">→</span>
        </a>
      </div>
