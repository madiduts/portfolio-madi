<section id="contact" class="relative py-20 px-6 md:px-12 max-w-5xl mx-auto border-t border-zinc-900/50">
  <!-- Glowing Background Accent -->
  <div class="absolute bottom-1/3 left-1/2 -translate-x-1/2 w-96 h-96 bg-teal-500/5 rounded-full blur-[150px] pointer-events-none"></div>

  <div class="relative z-10 space-y-12 max-w-4xl mx-auto text-center md:text-left">
    <!-- Header -->
    <div class="space-y-2">
      <div class="text-xs font-mono text-zinc-555 uppercase tracking-widest flex items-center justify-center md:justify-start gap-2">
        <span>04 //</span>
        <span>Connection Portal</span>
        <span class="h-[1px] w-12 bg-zinc-800"></span>
      </div>
      <h2 class="text-3xl font-sans font-bold text-white tracking-tight">
        Get In Touch
      </h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-12 gap-8 items-center">
      <!-- Call to Action Intro (Col Span 5) -->
      <div class="md:col-span-5 space-y-4 text-zinc-400 text-sm sm:text-base leading-relaxed font-sans pr-0 md:pr-6">
        <p>
          I am currently open to new opportunities, collaborations, and engineering discussions. 
          If you have a project in mind or just want to chat about system design, feel free to reach out through any of these channels.
        </p>
        <p class="text-xs font-mono text-zinc-550">
          SYS.STATUS // READY_FOR_INBOUND
        </p>
      </div>

      <!-- Social Media Cards (Col Span 7) -->
      <div class="md:col-span-7 grid grid-cols-1 gap-4 w-full">
        <!-- Email Card -->
        <a 
          href="mailto:mahdisutejo7@gmail.com" 
          class="card-spotlight flex items-center gap-4 p-4 bg-zinc-950/40 border border-zinc-900 hover:border-zinc-850 rounded-lg overflow-hidden transition-all duration-300 hover:scale-[1.01] cursor-pointer"
        >
          <!-- Neon glow overlay -->
          <div class="absolute inset-0 bg-teal-500/5 opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none"></div>
          
