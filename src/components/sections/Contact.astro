          target="_blank" 
          rel="noopener noreferrer" 
          class="card-spotlight flex items-center gap-4 p-4 bg-zinc-950/40 border border-zinc-900 hover:border-zinc-855 rounded-lg overflow-hidden transition-all duration-300 hover:scale-[1.01] cursor-pointer"
