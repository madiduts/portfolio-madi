---
import { getCollection } from 'astro:content';

const allProjects = await getCollection('projects');
const sortedProjects = allProjects.sort((a, b) => (a.data.order || 99) - (b.data.order || 99));

// Group into featured and archived/others
const featuredProjects = sortedProjects.filter(p => p.data.featured);
const otherProjects = sortedProjects.filter(p => !p.data.featured);
---

<section id="projects" class="relative py-20 px-6 md:px-12 max-w-5xl mx-auto border-t border-zinc-900/50">
  <!-- Glowing Background Accent -->
  <div class="absolute bottom-1/4 right-1/4 w-72 h-72 bg-teal-500/5 rounded-full blur-[100px] pointer-events-none"></div>

  <div class="relative z-10 space-y-12">
    <!-- Header -->
    <div class="space-y-2">
      <div class="text-xs font-mono text-zinc-550 uppercase tracking-widest flex items-center gap-2">
        <span>02 //</span>
        <span>Selected Work</span>
        <span class="h-[1px] w-12 bg-zinc-800"></span>
      </div>
      <h2 class="text-3xl font-sans font-bold text-white tracking-tight">
        Proyek Unggulan
      </h2>
    </div>

    <!-- Featured Projects Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      {featuredProjects.map(project => (
        <article class="card-spotlight group relative flex flex-col bg-zinc-950/40 border border-zinc-900 hover:border-zinc-800/80 rounded-lg overflow-hidden transition-all duration-300">
          <!-- Card Image Container -->
          {project.data.cover && (
            <div class="aspect-video w-full overflow-hidden bg-zinc-900 border-b border-zinc-900">
              <img 
                src={project.data.cover} 
                alt={project.data.title}
                width="600"
                height="337"
                loading="lazy"
                class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-102"
              />
            </div>
          )}

          <!-- Card Content -->
          <div class="p-6 flex flex-col flex-grow space-y-4">
            <!-- Project Meta -->
            <div class="flex items-center justify-between text-[10px] font-mono text-zinc-500">
              <span>{project.data.year}</span>
              <span class={`px-2 py-0.5 rounded-full text-[9px] uppercase tracking-wider ${
                project.data.status === 'completed' 
                  ? 'bg-teal-950/40 text-teal-400 border border-teal-900/30' 
                  : 'bg-amber-950/40 text-amber-400 border border-amber-900/30'
              }`}>
                {project.data.status}
              </span>
            </div>

            <!-- Title & Description -->
            <div class="space-y-2">
              <h3 class="text-xl font-sans font-bold text-white group-hover:text-teal-450 transition-colors duration-200">
                {project.data.title}
              </h3>
              <p class="text-sm text-zinc-400 leading-relaxed font-sans line-clamp-3">
                {project.data.description}
              </p>
            </div>

            <!-- Tags -->
            <div class="flex flex-wrap gap-1.5 pt-2">
              {project.data.tags.map(tag => (
                <span class="px-2 py-0.5 rounded bg-zinc-900 border border-zinc-850 text-[10px] font-mono text-zinc-400">
                  {tag}
                </span>
              ))}
            </div>

            <!-- Action Links -->
            {project.data.links && (
              <div class="flex items-center gap-4 pt-4 mt-auto border-t border-zinc-900 text-xs font-mono text-zinc-400">
                {project.data.links.github && (
                  <a 
                    href={project.data.links.github}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="hover:text-teal-400 transition-colors duration-200"
                  >
                    [Source Code]
                  </a>
                )}
                {project.data.links.live && (
                  <a 
                    href={project.data.links.live}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="hover:text-teal-400 transition-colors duration-200"
                  >
                    [Live Demo]
                  </a>
                )}
              </div>
            )}
          </div>
        </article>
      ))}
    </div>

    <!-- Secondary / Other Projects Section -->
    {otherProjects.length > 0 && (
      <div class="pt-8 space-y-6">
        <h3 class="text-sm font-mono text-zinc-400 uppercase tracking-widest">
          Proyek Lainnya
        </h3>
        <div class="grid grid-cols-1 gap-4">
          {otherProjects.map(project => (
            <div class="flex flex-col sm:flex-row sm:items-center justify-between p-4 bg-zinc-950/20 border border-zinc-900 hover:border-zinc-850 rounded transition-all duration-200 gap-4">
              <div class="space-y-1">
                <span class="text-xs font-mono text-zinc-550 mr-2">{project.data.year}</span>
                <span class="text-sm font-sans font-bold text-white hover:text-teal-450 transition-colors duration-200">
                  {project.data.title}
                </span>
                <p class="text-xs text-zinc-450 max-w-xl font-sans">
                  {project.data.description}
                </p>
              </div>

              <!-- Tags & Links -->
              <div class="flex flex-wrap items-center gap-4 text-xs font-mono">
                <div class="flex gap-1">
                  {project.data.tags.slice(0, 3).map(tag => (
                    <span class="px-1.5 py-0.5 text-[9px] text-zinc-500 border border-zinc-900 rounded">
                      {tag}
                    </span>
                  ))}
                </div>
                {project.data.links && (
                  <div class="flex gap-3 text-zinc-400">
                    {project.data.links.github && (
                      <a href={project.data.links.github} target="_blank" rel="noopener noreferrer" class="hover:text-teal-400">[Src]</a>
                    )}
                    {project.data.links.live && (
                      <a href={project.data.links.live} target="_blank" rel="noopener noreferrer" class="hover:text-teal-400">[Live]</a>
                    )}
                  </div>
                )}
              </div>
            </div>
          ))}
        </div>
      </div>
    )}
  </div>
</section>

<script>
  // Track cursor offset relative to each project card to update local spotlight
  const cards = document.querySelectorAll('.card-spotlight');
  cards.forEach(card => {
    card.addEventListener('mousemove', (e) => {
      const rect = card.getBoundingClientRect();
      const x = (e as MouseEvent).clientX - rect.left;
      const y = (e as MouseEvent).clientY - rect.top;
      (card as HTMLElement).style.setProperty('--card-mouse-x', `${x}px`);
      (card as HTMLElement).style.setProperty('--card-mouse-y', `${y}px`);
    });
  });
</script>
